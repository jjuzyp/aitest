
<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>Dashboard Snapshot</title>
  <script src="https://cdn.plot.ly/plotly-2.35.2.min.js"></script>
  <style>
    :root {
      --bg: #f4f6fb;
      --card: #ffffff;
      --text: #111827;
      --muted: #6b7280;
      --line: #e5e7eb;
      --accent: #2563eb;
      --good: #059669;
      --bad: #dc2626;
      --sand: #f7f3ea;
      --mint: #e9f8ee;
      --blue: #eef5ff;
      --shadow: 0 8px 24px rgba(15, 23, 42, 0.06);
      --radius: 18px;
    }
    * { box-sizing: border-box; }
    body { margin: 0; background: var(--bg); color: var(--text); font-family: Inter, Segoe UI, Arial, sans-serif; }
    .wrap { max-width: 1700px; margin: 0 auto; padding: 24px; }
    .header { margin-bottom: 16px; }
    .title { font-size: 28px; font-weight: 800; margin: 0; }
    .subtitle { color: var(--muted); margin-top: 6px; font-size: 14px; }

    .filters {
      display: grid;
      grid-template-columns: 220px 220px minmax(260px, 1fr) auto auto;
      gap: 12px;
      align-items: end;
      margin-bottom: 18px;
    }
    .field, .btn { background: var(--card); border: 1px solid var(--line); border-radius: 14px; box-shadow: var(--shadow); }
    .field { padding: 10px 12px; }
    .field label { display: block; color: var(--muted); font-size: 12px; margin-bottom: 6px; }
    .field select, .field input { width: 100%; border: none; outline: none; font-size: 14px; background: transparent; color: var(--text); }
    .btn { height: 48px; padding: 0 18px; cursor: pointer; font-weight: 700; text-decoration: none; color: var(--text); display: inline-flex; align-items: center; justify-content: center; }
    .btn.primary { background: var(--accent); color: #fff; border-color: var(--accent); }

    .cards-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 16px; margin-bottom: 16px; }
    .metric-card { background: var(--card); border: 1px solid var(--line); border-radius: 16px; box-shadow: var(--shadow); overflow: hidden; }
    .metric-card.sand { background: var(--sand); }
    .metric-card.mint { background: var(--mint); }
    .metric-card.blue { background: var(--blue); }
    .metric-body { padding: 16px 18px; }
    .metric-title { font-size: 13px; color: var(--muted); margin-bottom: 6px; }
    .metric-value { font-size: 32px; font-weight: 800; }
    .metric-subgrid { border-top: 1px solid rgba(17,24,39,0.08); display: grid; grid-template-columns: 1fr auto; gap: 8px 12px; padding: 12px 18px 16px; font-size: 14px; }
    .metric-subgrid .label { color: var(--text); opacity: 0.9; }
    .metric-subgrid .value { text-align: right; }

    .card { background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); box-shadow: var(--shadow); padding: 18px; }
    .section-title { font-size: 18px; font-weight: 800; margin: 4px 0 12px; }
    #dailyChart { width: 100%; height: 430px; min-height: 430px; max-height: 430px; }

    .top-products {
      display: grid;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: 16px;
      margin-top: 16px;
      margin-bottom: 16px;
    }
    .product-card { padding: 0; overflow: hidden; display: flex; flex-direction: column; min-height: 340px; }
    .product-body { padding: 14px 16px 16px; display: flex; flex-direction: column; gap: 10px; flex: 1; }
    .badge { display: inline-flex; align-items: center; padding: 4px 8px; border-radius: 999px; font-size: 12px; background: #eef2ff; color: #4338ca; width: fit-content; font-weight: 700; }
    .product-name { font-size: 15px; font-weight: 700; line-height: 1.35; min-height: 40px; }
    .product-meta { color: var(--muted); font-size: 12px; }
    .stats-mini { display: grid; grid-template-columns: 1fr 1fr; gap: 10px 14px; margin-top: auto; }
    .stat-mini-label { color: var(--muted); font-size: 12px; }
    .stat-mini-value { font-weight: 800; font-size: 15px; }

    .two-col { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 16px; margin-top: 16px; }
    .table-wrap { overflow: auto; max-height: 560px; border: 1px solid var(--line); border-radius: 14px; }
    table { width: 100%; border-collapse: collapse; background: #fff; }
    thead th {
      position: sticky; top: 0; background: #f9fafb; z-index: 1; text-align: left;
      font-size: 12px; color: var(--muted); padding: 12px; border-bottom: 1px solid var(--line); white-space: nowrap;
    }
    tbody td { padding: 12px; border-bottom: 1px solid #f1f5f9; font-size: 14px; white-space: nowrap; }
    tbody tr:hover { background: #fafcff; }
    .num { text-align: right; }
    .good { color: var(--good); }
    .bad { color: var(--bad); }
    .manifest { margin-top: 16px; font-size: 13px; color: var(--muted); }
    .ads-grid { display: grid; grid-template-columns: repeat(6, minmax(0, 1fr)); gap: 12px; margin-bottom: 16px; }
    .mini-kpi { background: #f8fafc; border: 1px solid var(--line); border-radius: 14px; padding: 12px 14px; }
    .mini-kpi-label { font-size: 12px; color: var(--muted); margin-bottom: 4px; }
    .mini-kpi-value { font-size: 20px; font-weight: 800; }
    .tab-row { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 14px; }
    .tab {
      border: 1px solid var(--line);
      background: #fff;
      color: var(--text);
      border-radius: 999px;
      padding: 8px 14px;
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
    }
    .tab.active { background: var(--accent); color: #fff; border-color: var(--accent); }
    .tab-panel { display: none; }
    .tab-panel.active { display: block; }
    .product-cell { display: flex; align-items: center; gap: 10px; min-width: 260px; }
    .product-copy { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
    .product-copy .name { font-weight: 700; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 260px; }
    .product-copy .meta { color: var(--muted); font-size: 12px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 260px; }
    .campaign-copy { display: flex; flex-direction: column; gap: 3px; min-width: 280px; }
    .campaign-copy .name { font-weight: 700; white-space: normal; line-height: 1.35; }
    .campaign-copy .meta { color: var(--muted); font-size: 12px; }
    .funnel-layout { display: grid; grid-template-columns: 220px 1fr; gap: 16px; align-items: start; }
    .funnel-metrics { display: flex; flex-direction: column; gap: 8px; }
    .funnel-metric { border: 0; background: transparent; color: var(--text); text-align: left; border-radius: 10px; padding: 10px 12px; cursor: pointer; font-size: 14px; }
    .funnel-metric.active { background: #f1ebff; color: #6d28d9; font-weight: 700; }
    .funnel-chart-wrap { min-height: 340px; }
    .daily-metrics-table td:first-child { white-space: normal; min-width: 240px; }

    @media (max-width: 1400px) {
      .top-products { grid-template-columns: repeat(4, minmax(0, 1fr)); }
      .cards-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .ads-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    }
    @media (max-width: 1280px) {
      .filters { grid-template-columns: 1fr 1fr; }
      .two-col { grid-template-columns: 1fr; }
      .top-products { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    }
    @media (max-width: 760px) {
      .filters, .cards-grid, .top-products { grid-template-columns: 1fr; }
      .funnel-layout { grid-template-columns: 1fr; }
      .wrap { padding: 16px; }
    }
  </style>
</head>
